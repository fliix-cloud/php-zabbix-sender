{
	"name": "fliix/php-zabbix-sender",
	"type": "library",
	"description": "PHP Implementation of Zabbix Sender (supports Zabbix 7.x).",
	"require": {
		"php": ">=8.2",
		"ext-sockets": "*",
		"symfony/options-resolver": "^7.2",
		"symfony/validator": "^7.2"
	},
	"license": "Apache-2.0",
	"support": {
		"issues": "https://github.com/fliix-cloud/php-zabbix-sender/issues",
		"source": "https://github.com/fliix-cloud/php-zabbix-sender"
	},
	"minimum-stability": "stable",
	"autoload": {
		"psr-4": {
			"Fliix\\ZabbixSender\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Fliix\\ZabbixSender\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^11.5",
		"friendsofphp/php-cs-fixer": "^3.75"
	},
	"archive": {
		"exclude": [
			".editorconfig",
			".gitattributes",
			".gitignore",
			"tests/",
			".php-cs-fixer.dist.php"
		]
	},
	"config": {
		"optimize-autoloader": true,
		"platform": {
			"php": "8.2"
		}
	},
	"scripts": {
		"cs": [
			"php-cs-fixer fix --ansi --dry-run --diff"
		],
		"cs-fix": [
			"php-cs-fixer fix --ansi"
		],
		"check": [
			"@cs"
		]
	}
}
